# === OAuth endpoint ============================================================
AUTH_URL=https://camunda.local/auth/realms/camunda-platform/protocol/openid-connect/token

# === Venom test client =========================================================
TEST_CLIENT_ID=venom
TEST_CLIENT_SECRET=VeryLongString

# === Camunda component service-accounts (confidential clients) ================
CONNECTORS_CLIENT_SECRET=VeryLongString
TASKLIST_CLIENT_SECRET=VeryLongString
OPERATE_CLIENT_SECRET=VeryLongString
OPTIMIZE_CLIENT_SECRET=VeryLongString
ZEEBE_CLIENT_SECRET=VeryLongString

# === Public base URLs (Ingress) ===============================================
CONSOLE_BASE_URL=https://camunda.local/console
KEYCLOAK_BASE_URL=https://camunda.local/auth
IDENTITY_BASE_URL=https://camunda.local/identity/
OPERATE_BASE_URL=https://camunda.local/operate
OPTIMIZE_BASE_URL=https://camunda.local/optimize
TASKLIST_BASE_URL=https://camunda.local/tasklist
WEBMODELER_BASE_URL=https://camunda.local/modeler
CONNECTORS_BASE_URL=https://camunda.local/connectors/inbound

# === Login URLs ================================================================
CONSOLE_LOGIN_PATH=/
KEYCLOAK_LOGIN_PATH=/
IDENTITY_LOGIN_PATH=
OPERATE_LOGIN_PATH=/
OPTIMIZE_LOGIN_PATH=/
TASKLIST_LOGIN_PATH=/
WEBMODELER_LOGIN_PATH=/
CONNECTORS_LOGIN_PATH=/

# === Zeebe gateways ============================================================
ZEEBE_GATEWAY_GRPC=zeebe.camunda.local:443
ZEEBE_GATEWAY_REST=https://camunda.local/zeebe

# === zbctl extras (optional) ===================================================
ZBCTL_EXTRA_ARGS=
# === feature toggles ===========================================================
SKIP_TEST_INGRESS=false   # set true to skip all ingress checks
SKIP_TEST_WEBMODELER=false # set true to skip WebModeler test
